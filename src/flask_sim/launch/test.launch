<launch>

  <!-- ==================== -->
  <!-- GazelleSim Arguments -->
  <!-- ==================== -->
  <arg name="show_dynamic_reconfigure" default="true" />
  <arg name="show_steering" default="false" />
  <arg name="show_cam_param" default="false" /> 


  <!-- ========================= -->
  <!-- Set simulation parameters -->
  <!-- ========================= -->
  <param name="map_dir" value="$(find flask_sim)/map" />
  <rosparam command="load"
            file="$(find flask_sim)/map/map.yaml" />


  <!-- ============= -->
  <!-- Define robots -->
  <!-- ============= -->
  <rosparam>
    robot_list: ["robot1"]
  </rosparam>
  
  <!-- Define robot1 -->
  <group ns="robot1">
    <node name="node1" pkg="flask_sim" type="test1.py" 
       required="true" output="screen">
    	<param name="imgtopic_name" type="str" value="camera/image_raw" /> 
      <param name="gps_name" type="str" value="gps" />   
      <param name="pos_name" type="str" value="odom" /> 
    </node>
    <rosparam command="load"
              file="$(find flask_sim)/robot/ACTor.yaml" />
    <rosparam>
        Xr_init: 20.6
        Yr_init:  -8.8
        Theta_init: deg(0.0)
    </rosparam>
  </group>

  <!-- Define robot2 -->
  <!-- <group ns="robot2">
    <node name="node2" pkg="v2x_sim" type="test8.py" 
       required="true" output="screen">
    	<param name="imgtopic_name" type="str" value="camera/image_raw" />  
      <param name="gps_name" type="str" value="gps" /> 
    </node>

    <rosparam command="load"
              file="$(find v2x_sim)/robot/ACTor.yaml" />
    <rosparam>
        Xr_init: 21.42
        Yr_init:  14.52
        Theta_init: deg(180.0)
    </rosparam>
  </group> -->
  
  <!-- ================= -->
  <!-- Launch GazelleSim -->
  <!-- ================= -->
  <include file="$(find gazelle_sim)/launch/gazelle_sim.launch">
    <arg name="show_dynamic_reconfigure" value="$(arg show_dynamic_reconfigure)" />
    <arg name="show_steering" value="$(arg show_steering)" />
    <arg name="show_cam_param" value="$(arg show_cam_param)" />
  </include>


</launch>
